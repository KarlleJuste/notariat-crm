NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
HUBSPOT_API_KEY=
STRIPE_SECRET_KEY=

# Sync MRR automatique (Vercel Cron → GET /api/cron/stripe-mrr toutes les 15 min)
# Sync HubSpot (GET /api/cron/hubspot-sync toutes les 30 min) — mêmes deals que « Rafraîchir »
# À définir aussi dans Vercel : CRON_SECRET (Bearer envoyé par la plateforme)
CRON_SECRET=

# Optionnel : limiter le cron HubSpot à certains événements (UUID séparés par des virgules)
# HUBSPOT_CRON_EVENT_IDS=

# Scripts locaux (tsx) : npm run debug:mrr | npm run sync:stripe | npm run hubspot:refresh-all

# Optionnel : liens directs vers les fiches deals HubSpot
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=

# Accès sans email : mot de passe seul (défaut : primmo2026)
# PRIMMO_TEAM_PASSWORD=
# Compte Auth technique partagé (défaut : acces@primmo.internal)
# NEXT_PUBLIC_PRIMMO_GATE_EMAIL=
